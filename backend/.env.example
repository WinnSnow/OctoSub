# System auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=admin
AUTH_SECRET=<generate-a-long-random-secret>
AUTH_COOKIE_SECURE=false

# Runtime paths
# Defaults are resolved to <project>/runtime/* by backend/config.py.
# DATA_DIR=/absolute/path/to/runtime/data
# SESSION_DIR=/absolute/path/to/runtime/sessions
# LOG_DIR=/absolute/path/to/runtime/logs
# DB_PATH=/absolute/path/to/runtime/data/telegram_data.db
# SESSION_NAME=/absolute/path/to/runtime/sessions/anon_dev

# Telegram
API_ID=0
API_HASH=

# Search
PUBLIC_SEARCH_CHANNELS=
PUBLIC_SEARCH_TTL_SECONDS=1200
# Docker Compose uses http://pansou:8888. For local/manual PanSou, use http://127.0.0.1:8888 or your own service address.
PANSOU_BASE_URL=http://pansou:8888
PANSOU_ENABLED=true

# TMDB
TMDB_API_KEY=

# Douban
# Optional. Explicit keys are recommended; missing keys may fall back to legacy
# compatibility defaults and will be reported in system diagnostics.
DOUBAN_ENABLED=true
DOUBAN_BASE_URL=https://frodo.douban.com/api/v2
DOUBAN_API_KEY=
DOUBAN_API_SECRET=
DOUBAN_TIMEOUT_SECONDS=8
DOUBAN_SEARCH_TTL_SECONDS=21600
DOUBAN_DETAIL_TTL_SECONDS=259200
DOUBAN_RECOMMENDATION_TTL_SECONDS=43200

# 115 / WeCom forwarding
FORWARD_URL=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=
WECOM_CORP_ID=

# CMS polling
CMS_BASE_URL=
CMS_SHARE_DOWN_LIST_URL=
CMS_TRANSFER_POLL_ENABLED=true

# Jellyfin
JELLYFIN_URL=
JELLYFIN_API_KEY=

# Subscriptions
SUBSCRIPTION_ENABLED=true
SUBSCRIPTION_CHECK_HOUR=2
SUBSCRIPTION_CHECK_MINUTE=0
